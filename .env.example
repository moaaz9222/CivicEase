# ════════════════════════════════════════════════════════════════════
#  CivicEase AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file — it is already in .gitignore.
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Model (optional — default is fast & free) ────────────────────
# Recommended options:
#   llama-3.1-8b-instant   ← fastest, free tier (default)
#   llama3-70b-8192        ← more powerful, higher latency
#   mixtral-8x7b-32768     ← alternative, good reasoning
GROQ_MODEL_NAME=llama-3.1-8b-instant

# ── Embedding Model (optional — default downloads automatically) ──────
# Used for RAG vector search. Downloads ~90MB on first run.
# Recommended options:
#   all-MiniLM-L6-v2              ← fast, lightweight (default)
#   all-mpnet-base-v2             ← more accurate, slower
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Flask Server (optional) ───────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-this-to-a-random-secret-in-production

# ── Logging (optional) ────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Background ingestion (optional)
# Enable to run incremental ChromaDB upserts in a daemon APScheduler worker.
CIVICEASE_ENABLE_BACKGROUND_INGESTION=false
CIVICEASE_INGESTION_INTERVAL_MINUTES=30
CIVICEASE_SCHEDULER_TIMEZONE=UTC

# ChromaDB collection used by the RAG retriever and upsert pipeline.
CHROMA_COLLECTION_NAME=langchain
